<ContentDialog
    x:Class="FSPSWinUI.Views.ProfileDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FSPSWinUI.Views"
    xmlns:vm="using:FSPSWinUI.ViewModels"
    Title="{x:Bind ViewModel.DialogTitle, Mode=OneWay}"
    PrimaryButtonText="OK"
    SecondaryButtonText="Abbrechen"
    DefaultButton="Primary"
    x:Name="DialogRoot"
    HorizontalContentAlignment="Stretch">

    <Grid Padding="0,8,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Text="Name" Grid.Row="0" Margin="0,0,0,4" />
        <TextBox Text="{x:Bind ViewModel.Name, Mode=TwoWay}" Grid.Row="1" MinWidth="320" MinHeight="32" Margin="0,0,0,8" />
        <TextBlock Text="Ordnerpfad" Grid.Row="2" Margin="0,0,0,4" />
        <StackPanel Orientation="Horizontal" Grid.Row="3">
            <TextBox Text="{x:Bind ViewModel.Path, Mode=TwoWay}" MinWidth="240" MinHeight="32" Width="240" />
            <Button Content="..." Margin="8,0,0,0" Click="BrowseButton_Click" />
        </StackPanel>
    </Grid>
</ContentDialog>
